{
  "name": "@games/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/drizzle/schema.ts",
    "./games/shikaku-engine": "./src/games/shikaku-engine.ts",
    "./games/pips-engine": "./src/games/pips-engine.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:local": "vitest run --config vitest.local.config.ts --passWithNoTests",
    "test:watch": "vitest --watch",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@rocicorp/zero": "1.8.0",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "pg": "^8.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
