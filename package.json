{
  "name": "games-refac",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "local:up": "powershell -ExecutionPolicy Bypass -File ./scripts/local-dev.ps1",
    "local:down": "powershell -ExecutionPolicy Bypass -File ./scripts/local-down.ps1",
    "local:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/local-down.ps1 -SkipPorts && powershell -ExecutionPolicy Bypass -File ./scripts/local-dev.ps1",
    "local:up:mac": "bash ./scripts/local-dev.sh",
    "local:down:mac": "bash ./scripts/local-down.sh",
    "local:reset:mac": "bash ./scripts/local-down.sh --skip-ports && bash ./scripts/local-dev.sh",
    "local:up:linux": "bash ./scripts/local-dev.sh",
    "local:up:linux:host": "bash ./scripts/local-dev.sh --host",
    "local:down:linux": "bash ./scripts/local-down.sh",
    "local:reset:linux": "bash ./scripts/local-down.sh --skip-ports && bash ./scripts/local-dev.sh",
    "build": "turbo run build --cache-dir=.turbo-cache",
    "test": "turbo run test --cache-dir=.turbo-cache",
    "test:ci": "turbo run test:ci --cache-dir=.turbo-cache",
    "test:local": "bun --filter @games/shared test:local",
    "test:watch": "bun --filter @games/shared test:watch",
    "lint": "turbo run lint --cache-dir=.turbo-cache",
    "typecheck": "turbo run typecheck --cache-dir=.turbo-cache",
    "db:push": "bun --filter @games/shared db:push",
    "db:push:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/db-push-prod.ps1",
    "db:push:prod:linux": "bash ./scripts/db-push-prod.sh",
    "db:generate": "bun --filter @games/shared db:generate",
    "db:studio": "bun --filter @games/shared db:studio"
  },
  "devDependencies": {
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
