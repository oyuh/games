{
  "name": "games-refac",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @games/shared db:push",
    "db:generate": "pnpm --filter @games/shared db:generate",
    "db:studio": "pnpm --filter @games/shared db:studio"
  },
  "devDependencies": {
    "turbo": "^2.8.15",
    "typescript": "^5.9.3"
  }
}
