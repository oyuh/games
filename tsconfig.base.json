{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@games/shared": ["./packages/shared/src/index.ts"],
      "@games/shared/db": ["./packages/shared/src/drizzle/schema.ts"],
      "@games/shared/*": ["./packages/shared/src/*"]
    }
  }
}
